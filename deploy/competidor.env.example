# Copie para /etc/competidor.env, troque os segredos e mantenha permissao 600.
PORT=8770
COMPETIDOR_DATA_DIR=/var/lib/competidor
COMPETIDOR_PERFORMANCE_PROFILE=shared-8gb
COMPETIDOR_MEMORY_MAINTENANCE_SECONDS=300
COMPETIDOR_MEMORY_TRIM_RSS_MB=3072
COMPETIDOR_ENABLE_DEV_HTTPS=0
COMPETIDOR_GC_GENERATION0_THRESHOLD=50000
SESSION_SECONDS=2592000

MELI_CLIENT_ID=troque_pelo_client_id
MELI_CLIENT_SECRET=troque_pelo_client_secret
MELI_REDIRECT_URI=https://competidor.umsoftware.com.br/api/oauth/callback

# Servidor HTTP e filas. O perfil foi dimensionado para 6 vCPU e 8 GB
# compartilhados com as demais aplicacoes.
COMPETIDOR_HTTP_MAX_CONCURRENT_REQUESTS=64
COMPETIDOR_HTTP_REQUEST_QUEUE=128
COMPETIDOR_HTTP_KEEPALIVE_TIMEOUT_SECONDS=30
COMPETIDOR_HTTP_POOL_IDLE_PER_HOST=16
COMPETIDOR_GZIP_THRESHOLD_BYTES=2048
COMPETIDOR_MANUAL_CONCURRENT_JOBS=4
MELI_CLONE_CONCURRENT_JOBS=4
COMPETIDOR_BACKGROUND_CONCURRENT_JOBS=2
COMPETIDOR_HEAVY_CONCURRENT_JOBS=1

# A API do Mercado Livre continua sendo o limite externo. As pistas abaixo
# priorizam acoes manuais e evitam excesso de 429/503.
MELI_INTERACTIVE_MAX_IN_FLIGHT=8
MELI_BACKGROUND_MAX_IN_FLIGHT=6
MELI_INTERACTIVE_TIMEOUT_SECONDS=8
MELI_INTERACTIVE_RETRIES=2
MELI_REQUEST_TIMEOUT_SECONDS=20

# Sincronizacao completa e descoberta incremental.
AUTO_SYNC_INTERVAL_SECONDS=180
AUTO_SYNC_STARTUP_DELAY_SECONDS=30
AUTO_DISCOVERY_ITEMS_PER_STATUS=100
AUTO_DISCOVERY_STATUSES=active,paused,under_review
AUTO_OPERATIONS_SYNC_EVERY_N_RUNS=5
AUTO_REFRESH_BATCH_SIZE=1500
AUTO_REFRESH_BATCH_WORKERS=6
MELI_SYNC_STATUSES=active,paused,under_review
MELI_SCAN_MAX_PAGES=1000
MELI_SYNC_INLINE_LIMIT=200
MELI_SYNC_COMPETITION_INLINE_LIMIT=0
MELI_SYNC_CONCURRENT_ACCOUNTS=2
MELI_SYNC_LIST_WORKERS=3
MELI_SYNC_LIST_TIMEOUT_SECONDS=12
MELI_SYNC_LIST_RETRIES=3
MELI_SYNC_BATCH_WORKERS=6
MELI_SYNC_FALLBACK_WORKERS=4
MELI_SYNC_RESUME_DELAY_SECONDS=2
MELI_ITEM_BULK_SIZE=20

# Buy box/catalogo. Webhooks atualizam eventos imediatamente; esta varredura
# rotativa e a contingencia para eventos que o Mercado Livre nao entregar.
AUTO_COMPETITION_INTERVAL_SECONDS=30
AUTO_COMPETITION_STARTUP_DELAY_SECONDS=45
AUTO_COMPETITION_BATCH_SIZE=250
AUTO_COMPETITION_WORKERS=10
AUTO_COMPETITION_REQUEST_DELAY_SECONDS=0
MELI_CATALOG_OFFERS_CACHE_SECONDS=900
MELI_PUBLIC_BUYBOX_CACHE_SECONDS=300
MELI_PUBLIC_PAGE_TIMEOUT_SECONDS=4

# Webhooks e operacao.
MELI_NOTIFICATION_DEBOUNCE_SECONDS=0.25
MELI_NOTIFICATION_BATCH_SIZE=200
SCAN_INTERVAL_SECONDS=300
MELI_PENDING_SLA_LIMIT=100
MELI_CLAIM_DETAIL_LIMIT=20
AUTO_SHIPPING_COST_BATCH_SIZE=20
AUTO_SALE_FEE_BATCH_SIZE=20
AUTO_SALE_FEE_INTERVAL_SECONDS=60
AUTO_SALE_FEE_STARTUP_DELAY_SECONDS=50
AUTO_SALE_FEE_BACKFILL_BATCH_SIZE=30
AUTO_SALE_FEE_WORKERS=6
MELI_SALE_FEE_ERROR_RETRY_SECONDS=900
MELI_SALE_FEE_NOT_AVAILABLE_RETRY_SECONDS=21600
MELI_SHIPPING_COST_ON_DEMAND_LIMIT=25
MELI_SALE_FEE_ON_DEMAND_LIMIT=25
MELI_GTIN_ON_DEMAND_LIMIT=15

# Copia, relatorios e planilhas pesadas permanecem em filas limitadas.
MELI_CLONE_SOURCE_CACHE_SECONDS=900
MELI_CLONE_EXCLUDED_SALE_TERMS=SUBSCRIBABLE
SELLER_PROFILE_CACHE_SECONDS=86400
CATEGORY_ATTRIBUTES_CACHE_SECONDS=21600
MELI_CLONE_RATE_LIMIT_RETRIES=3
MELI_CLONE_RATE_LIMIT_BASE_SECONDS=1.5
MELI_CLONE_RATE_LIMIT_MAX_SECONDS=8
MELI_CLONE_MAX_COMBINATIONS=20
MELI_STATISTICS_ORDERS_LIMIT=50000
MELI_STATISTICS_MAX_DAYS=366
MELI_STATISTICS_WINDOW_DAYS=31
MELI_STATISTICS_SHIPMENT_LOOKUPS=500
MELI_STATISTICS_FLEX_LOOKUPS=5000
MELI_STATISTICS_SHIPMENT_CACHE_SECONDS=86400
MELI_STATISTICS_CACHE_SECONDS=300
MELI_STATISTICS_JOB_TTL_SECONDS=21600
MELI_REPORT_MAX_ROWS=100000
MELI_REPORT_PDF_CHUNK_ROWS=1000
MELI_REPORT_JOB_TTL_SECONDS=21600
MELI_SPREADSHEET_JOB_TTL_SECONDS=21600
MELI_SPREADSHEET_MAX_ROWS=10000
MELI_SPREADSHEET_MAX_CHANGES=500
MAX_REQUEST_BODY_BYTES=31457280
ASYNC_OPERATION_TTL_SECONDS=1800
